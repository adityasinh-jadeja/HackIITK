# ============================================
# Secure Agentic Browser — Environment Config
# ============================================
# Copy this file to .env and fill in your keys.

# --- LLM Provider ---
# Options: "gemini", "groq", "ollama"
# Gemini has much higher rate limits (recommended for agent tasks)
# Groq is faster but has strict free-tier limits (429 errors)
LLM_PROVIDER=gemini

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/secure_browser

# --- Server ---
PORT=8000
HOST=0.0.0.0

# --- Security Thresholds ---
RISK_THRESHOLD_WARN=40
RISK_THRESHOLD_APPROVAL=65
RISK_THRESHOLD_BLOCK=85

# --- Browser Sandbox ---
PLAYWRIGHT_HEADLESS=true
MAX_PAGE_LOAD_TIMEOUT=30000
MAX_CONCURRENT_CONTEXTS=5

# --- Ollama (only if LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
